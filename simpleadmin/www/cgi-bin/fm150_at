#!/bin/bash
# FM150 AT command endpoint.  The argument is never evaluated by a shell.

printf 'Content-Type: text/plain; charset=utf-8\r\n\r\n'

urldecode() {
    local value="${1//+/ }"
    printf '%b' "$(printf '%s' "$value" | sed 's/%/\\x/g')"
}

encoded=$(printf '%s' "$QUERY_STRING" | tr '&' '\n' | sed -n 's/^atcmd=//p' | head -n 1)
ATCMD=$(urldecode "$encoded")

if [ -z "$ATCMD" ] || [ "${#ATCMD}" -gt 256 ]; then
    printf 'ERROR: missing or oversized AT command\n'
    exit 1
fi

# Accept AT syntax only.  More importantly, forbid line breaks so one HTTP
# request cannot inject a second serial command.
case "$ATCMD" in
    AT|AT+*|AT\&*) ;;
    *) printf 'ERROR: command must start with AT\n'; exit 1 ;;
esac
case "$ATCMD" in
    *$'\r'*|*$'\n'*) printf 'ERROR: line breaks are not allowed\n'; exit 1 ;;
esac

# The verified FM150-AE/NA-01 AT channel is smd9, exposed by the existing
# bridge as ttyOUT / atcmd11.  Do not replace the user's bridge here.
AT_BRIDGE=${FM150_AT_BRIDGE:-/usrdata/socat-at-bridge/atcmd11}
if [ ! -x "$AT_BRIDGE" ]; then
    AT_BRIDGE=/bin/atcmd11
fi
if [ ! -x "$AT_BRIDGE" ]; then
    printf 'ERROR: FM150 AT bridge not found; set FM150_AT_BRIDGE or provide /usrdata/socat-at-bridge/atcmd11\n'
    exit 1
fi

# The serial port is single-client.  Avoid interleaving requests from polling
# and button clicks, which otherwise corrupts AT responses.
LOCK=/tmp/fm150-at.lock
attempt=0
until mkdir "$LOCK" 2>/dev/null; do
    # A modem restart or an interrupted CGI can leave an empty lock directory.
    # If its recorded owner no longer exists, reclaim it automatically.
    if [ -r "$LOCK/pid" ]; then
        owner=$(cat "$LOCK/pid" 2>/dev/null || true)
        if [ -n "$owner" ] && ! kill -0 "$owner" 2>/dev/null; then
            rm -f "$LOCK/pid"
            rmdir "$LOCK" 2>/dev/null || true
            continue
        fi
    else
        rmdir "$LOCK" 2>/dev/null || true
    fi
    attempt=$((attempt + 1))
    if [ "$attempt" -ge 50 ]; then
        printf 'ERROR: another AT command is still running\n'
        exit 1
    fi
    sleep 0.1
done
printf '%s\n' "$$" > "$LOCK/pid"
trap 'rm -f "$LOCK/pid"; rmdir "$LOCK" 2>/dev/null' EXIT

printf '%s\n\n' "$ATCMD"
ESC=$(printf '\033')
# This firmware's BusyBox timeout applet accepts -t SECONDS COMMAND. The
# five-second watchdog prevents a stuck AT request from holding the lock.
timeout -t 5 "$AT_BRIDGE" "$ATCMD" | sed "s/${ESC}\\[[0-9;]*m//g" | tr -d '\r'
