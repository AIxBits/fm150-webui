#!/bin/bash
# FM150 smd9 bridge client.  The reader is always cleaned up: this is
# essential when the command is invoked from a web CGI with a timeout.

DEVICE=${FM150_AT_DEVICE:-/dev/ttyOUT}
BAUD=${FM150_AT_BAUD:-115200}
WAIT_TENTHS=${FM150_AT_WAIT_TENTHS:-150} # fifteen seconds by default

setup_device() {
    stty -F "$DEVICE" cs8 "$BAUD" ignbrk -brkint -icrnl -imaxbel \
        -opost -onlcr -isig -icanon -iexten -echo -echoe -echok \
        -echoctl -echoke noflsh -ixon -crtscts
}

send_at_command() {
    local command="$1" tmpfile reader_pid tries=0
    tmpfile=$(mktemp) || return 1
    reader_pid=
    cleanup() {
        if [ -n "$reader_pid" ]; then
            kill "$reader_pid" 2>/dev/null || true
            wait "$reader_pid" 2>/dev/null || true
        fi
        rm -f "$tmpfile"
    }
    trap cleanup EXIT INT TERM HUP

    # Start consuming the PTY before writing the command; otherwise a fast
    # FM150 response can be missed between write and the old cat startup.
    cat "$DEVICE" > "$tmpfile" &
    reader_pid=$!
    : > "$DEVICE"
    printf '%s\r' "$command" > "$DEVICE"

    while ! grep -qe 'OK' -e 'ERROR' "$tmpfile"; do
        tries=$((tries + 1))
        if [ "$tries" -ge "$WAIT_TENTHS" ]; then
            printf 'ERROR: AT response timeout\n'
            cleanup
            trap - EXIT INT TERM HUP
            return 1
        fi
        sleep 0.1
    done

    kill "$reader_pid" 2>/dev/null || true
    wait "$reader_pid" 2>/dev/null || true
    reader_pid=
    cat "$tmpfile"
    trap - EXIT INT TERM HUP
    rm -f "$tmpfile"
}

setup_device || exit 1

if [ "$#" -gt 0 ]; then
    send_at_command "$*"
else
    printf "Type 'exit' to end the session.\n"
    while :; do
        printf 'Enter AT Command: '
        IFS= read -r user_input || break
        [ "$user_input" = 'exit' ] && break
        send_at_command "$user_input"
    done
fi
