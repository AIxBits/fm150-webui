[Unit]
Description=Read from /dev/ttyIN and write to smd9 (legacy smd11 unit name)
BindsTo=socat-smd11.service
After=socat-smd11.service

[Service]
ExecStart=/bin/bash -c "/bin/cat /dev/ttyIN > /dev/smd9"
ExecStartPost=/bin/sleep 2s
StandardInput=tty-force
Restart=always
RestartSec=1s

[Install]
WantedBy=multi-user.target
