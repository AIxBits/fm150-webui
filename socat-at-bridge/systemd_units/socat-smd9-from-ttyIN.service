[Unit]
Description=Read from /dev/ttyIN and write to FM150 smd9
BindsTo=socat-smd9.service
After=socat-smd9.service

[Service]
ExecStart=/bin/bash -c "/bin/cat /dev/ttyIN > /dev/smd9"
ExecStartPost=/bin/sleep 2s
StandardInput=tty-force
Restart=always
RestartSec=1s

[Install]
WantedBy=multi-user.target
